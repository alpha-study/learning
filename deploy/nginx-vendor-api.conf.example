# Include inside the server { } block for your production SPA host (e.g. publications.alpha.study).
# Then build with .env.production (VITE_API_BASE_URL=/vendor-api) and redeploy dist/.

location /vendor-api/ {
  proxy_pass https://dev.alpha.study/vendor/;
  proxy_ssl_server_name on;
  proxy_set_header Host dev.alpha.study;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Proto $scheme;
  client_max_body_size 10G;
}

location /assets/ {
  proxy_pass https://dev.alpha.study/assets/;
  proxy_ssl_server_name on;
  proxy_set_header Host dev.alpha.study;
}
