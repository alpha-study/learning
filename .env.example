# Copy to `.env` for local development (not committed).
# Production (Vercel): add these under Project → Settings → Environment Variables
# for the Production environment, then redeploy. Values are baked in at build time.

VITE_API_BASE_URL=https://dev.alpha.study/vendor
# Production on learning.alpha.study (proxied via vercel.json):
# VITE_API_BASE_URL=/vendor-api

VITE_VENDOR_ASSET_ORIGIN=https://dev.alpha.study

VITE_COURSE_MEDIA_UPLOAD_PATH=/api/course/upload_assets
VITE_COURSE_MEDIA_UPLOAD_FIELD=assetFile
VITE_COURSE_PROMO_VIDEO_MAX_BYTES=1073741824
VITE_COURSE_LECTURE_VIDEO_MAX_BYTES=10737418240

# Required — app crashes on load if these are missing in the production build
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
