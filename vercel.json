{
  "rewrites": [
    {
      "source": "/vendor-api/:path*",
      "destination": "https://dev.alpha.study/vendor/:path*"
    },
    {
      "source": "/assets/courses/:path*",
      "destination": "https://dev.alpha.study/assets/courses/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
